---
// components
import StatusPill from "./StatusPill.astro";
import VehicleSilhouette from "./VehicleSilhouette.astro";
import VehicleGallery from "./VehicleGallery.tsx";
import SpecIcon from "./SpecIcon.astro";
import BookingWidget from "./BookingWidget.tsx";

// others
import type { Vehicle, VehicleBusyRange } from "../../types";
import { categoryLabelPl, fuelLabelPl, formatPayloadKg, formatCargoDims, transmissionLabelPl } from "../../lib/format";

// The vehicle detail page — also step 1 ("Daty") of the reservation flow
// (design desktop-1). Left column: the hero (year · type, make + model title,
// status pill, image gallery), a 3-column SPECYFIKACJA icon grid, and a trust
// row. Right column (sticky on desktop): the <BookingWidget> island, which owns
// the date range, the live estimate, and the "Zarezerwuj" action that hands the
// vehicle id + chosen dates to /reserve (step 2). When the vehicle has photos
// the <VehicleGallery> island renders a swipeable carousel; otherwise it falls
// back to the per-category silhouette (storage is S-05).

interface Props {
  vehicle: Vehicle;
  pickup?: string | null;
  returnDate?: string | null;
  /** Pending + confirmed date bounds the booking calendar greys out (Phase 6). */
  busyRanges?: VehicleBusyRange[];
}

const { vehicle, pickup, returnDate, busyRanges = [] } = Astro.props;

const title = [vehicle.make ?? vehicle.name, vehicle.model].filter(Boolean).join(" ");

const specs = [
  { icon: "seats" as const, label: "Miejsca", value: vehicle.seats === null ? "—" : String(vehicle.seats) },
  { icon: "transmission" as const, label: "Skrzynia", value: transmissionLabelPl(vehicle.transmission) },
  { icon: "fuel" as const, label: "Paliwo", value: fuelLabelPl(vehicle.fuel_type) },
  { icon: "payload" as const, label: "Ładowność", value: formatPayloadKg(vehicle.payload_capacity_kg) },
  {
    icon: "cargo" as const,
    label: "Ładunek (D×S×W)",
    value: formatCargoDims(vehicle.cargo_length_cm, vehicle.cargo_width_cm, vehicle.cargo_height_cm),
  },
  {
    icon: "distance" as const,
    label: "Limit km",
    value: vehicle.km_limit === null ? "—" : `${vehicle.km_limit} km`,
  },
];

// Trust row (design desktop-1): static reassurance, not data-backed. The depot
// is the single fixed branch (no location model yet — same as HeroSearch).
const trust = [
  { title: "Płatność przy odbiorze", note: "Gotówką lub kartą w dniu odbioru" },
  { title: "Pełne ubezpieczenie", note: "OC + AC w każdym pojeździe" },
  { title: "Odbiór 24/7", note: "Warszawa · Mokotów" },
];
---

<article class="lg:max-w-app mx-auto max-w-2xl px-5 pb-32 sm:px-8 md:max-w-3xl lg:pb-16">
  <!-- Top bar: back link -->
  <div class="flex items-center justify-between py-5">
    <a
      href="/fleet"
      class="bg-card shadow-card text-foreground hover:bg-accent inline-flex size-10 items-center justify-center rounded-full transition-colors"
      aria-label="Wróć do floty"
    >
      <svg
        class="size-[18px]"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.8"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M19 12H5M11 18l-6-6 6-6"></path>
      </svg>
    </a>
  </div>

  <!-- Desktop (lg): scrolling detail (left) + sticky booking widget (right).
       Below lg everything stacks in one column. -->
  <div class="lg:grid lg:grid-cols-[1.5fr_1fr] lg:items-start lg:gap-10">
    <!-- Left: hero + specs + trust -->
    <div class="min-w-0">
      <!-- Hero -->
      <header class="bg-card shadow-card rounded-3xl px-6 pt-8 pb-7 text-center lg:px-10 lg:pt-10 lg:pb-9">
        <p class="text-muted-foreground text-xs font-semibold tracking-wide uppercase">
          {vehicle.production_year ? `${vehicle.production_year} · ` : ""}{categoryLabelPl(vehicle.category)}
        </p>
        <h1 class="text-foreground mt-2 text-4xl font-bold tracking-tight sm:text-5xl lg:text-[2.75rem]">{title}</h1>
        <div class="mt-3 inline-flex">
          <StatusPill />
        </div>

        <div class="text-foreground mt-4 lg:mt-7">
          {
            vehicle.photos.length > 0 ? (
              <VehicleGallery photos={vehicle.photos} alt={title} client:idle />
            ) : (
              <div class="flex items-center justify-center px-2">
                <VehicleSilhouette
                  category={vehicle.category}
                  photos={vehicle.photos}
                  alt={title}
                  class="max-w-[320px] lg:max-w-[420px]"
                />
              </div>
            )
          }
        </div>
      </header>

      <!-- Specifications: 3-column icon grid (design desktop-1). -->
      <section class="pt-7">
        <h2 class="text-muted-foreground px-1 pb-2.5 text-[13px] font-bold tracking-wide uppercase">Specyfikacja</h2>
        <dl class="grid grid-cols-2 gap-3 sm:grid-cols-3">
          {
            specs.map((spec) => (
              <div class="bg-card shadow-card flex flex-col gap-2 rounded-2xl p-4">
                <span class="bg-background text-foreground flex size-8 items-center justify-center rounded-[10px]">
                  <SpecIcon name={spec.icon} />
                </span>
                <dt class="text-muted-foreground text-[11px] font-semibold tracking-wide uppercase">{spec.label}</dt>
                <dd class="text-foreground text-sm font-semibold tracking-tight">{spec.value}</dd>
              </div>
            ))
          }
        </dl>
      </section>

      <!-- Trust / feature row (design desktop-1). -->
      <section class="mt-7 grid grid-cols-1 gap-3 sm:grid-cols-3">
        {
          trust.map((item) => (
            <div class="bg-card shadow-card flex items-start gap-3 rounded-2xl p-4">
              <span class="bg-success/10 text-success flex size-7 shrink-0 items-center justify-center rounded-full">
                <svg
                  class="size-4"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M5 13l4 4 10-10" />
                </svg>
              </span>
              <div class="min-w-0">
                <p class="text-foreground text-sm font-semibold tracking-tight">{item.title}</p>
                <p class="text-muted-foreground mt-0.5 text-xs leading-snug">{item.note}</p>
              </div>
            </div>
          ))
        }
      </section>
    </div>

    <!-- Right: booking widget (step 1). On mobile it stacks below, with a sticky
         bottom CTA bar (the calendar is far up the page). -->
    <div class="mt-7 lg:mt-0">
      <BookingWidget
        client:load
        vehicleId={vehicle.id}
        dailyRate={vehicle.daily_rate}
        monthlyRate={vehicle.monthly_rate}
        deposit={vehicle.deposit}
        initialPickup={pickup}
        initialReturn={returnDate}
        busyRanges={busyRanges}
      />
    </div>
  </div>
</article>
