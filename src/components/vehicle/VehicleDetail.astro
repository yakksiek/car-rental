---
// components
import StatusPill from "./StatusPill.astro";
import VehicleSilhouette from "./VehicleSilhouette.astro";
import VehicleGallery from "./VehicleGallery.tsx";
import SpecIcon from "./SpecIcon.astro";

// others
import type { Vehicle } from "../../types";
import {
  categoryLabelPl,
  formatPln,
  fuelLabelPl,
  formatPayloadKg,
  formatCargoDims,
  transmissionLabelPl,
} from "../../lib/format";

// The full vehicle detail card (design screen 03): a centered hero (year · type,
// make + model title, status pill, image gallery), a "SPECYFIKACJA" list, a
// "CENNIK" block with the full pricing, and a sticky "Zarezerwuj" CTA that hands
// the vehicle id + the visitor's selected dates to the S-02 reservation route.
// When the vehicle has photos, the <VehicleGallery> island renders a swipeable
// carousel (dots on mobile/tablet, thumbnails + arrows on desktop); with no
// photos it falls back to the static per-category silhouette (storage is S-05).

interface Props {
  vehicle: Vehicle;
  pickup?: string | null;
  returnDate?: string | null;
}

const { vehicle, pickup, returnDate } = Astro.props;

const title = [vehicle.make ?? vehicle.name, vehicle.model].filter(Boolean).join(" ");

// Reserve CTA → S-02 route. Carry the selected range when present so the funnel
// starts pre-filled; the destination (/reserve) is built in S-02.
const reserveParams = new URLSearchParams({ vehicle_id: vehicle.id });
if (pickup && returnDate) {
  reserveParams.set("pickup", pickup);
  reserveParams.set("return", returnDate);
}
const reserveHref = `/reserve?${reserveParams.toString()}`;

const specs = [
  { icon: "seats" as const, label: "Miejsca", value: vehicle.seats === null ? "—" : String(vehicle.seats) },
  { icon: "fuel" as const, label: "Paliwo", value: fuelLabelPl(vehicle.fuel_type) },
  { icon: "transmission" as const, label: "Skrzynia", value: transmissionLabelPl(vehicle.transmission) },
  {
    icon: "cargo" as const,
    label: "Ładunek (D×S×W)",
    value: formatCargoDims(vehicle.cargo_length_cm, vehicle.cargo_width_cm, vehicle.cargo_height_cm),
  },
  { icon: "payload" as const, label: "Ładowność", value: formatPayloadKg(vehicle.payload_capacity_kg) },
  {
    icon: "year" as const,
    label: "Rok",
    value: vehicle.production_year === null ? "—" : String(vehicle.production_year),
  },
];

const pricing = [
  { label: "Doba", value: formatPln(vehicle.daily_rate), big: true },
  { label: "Miesiąc", value: formatPln(vehicle.monthly_rate), big: true },
  { label: "Kaucja", value: formatPln(vehicle.deposit) },
  { label: "Limit km", value: vehicle.km_limit === null ? "—" : `${vehicle.km_limit} km` },
  { label: "Dodatk. km", value: `${formatPln(vehicle.per_extra_km_rate)}/km` },
  { label: "VAT", value: "Doliczany" },
];
---

<article class="mx-auto max-w-2xl px-5 pb-32 sm:px-8 md:max-w-3xl lg:max-w-6xl lg:pb-16">
  <!-- Top bar: back link + decorative actions -->
  <div class="flex items-center justify-between py-5">
    <a
      href="/fleet"
      class="bg-card shadow-card text-foreground hover:bg-accent inline-flex size-10 items-center justify-center rounded-full transition-colors"
      aria-label="Wróć do floty"
    >
      <svg
        class="size-[18px]"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.8"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M19 12H5M11 18l-6-6 6-6"></path>
      </svg>
    </a>
  </div>

  <!-- Desktop (lg) splits into a sticky hero (left) + scrolling details (right);
       below lg everything stacks in one column. -->
  <div class="lg:grid lg:grid-cols-[1.05fr_0.95fr] lg:items-start lg:gap-12">
    <!-- Hero -->
    <header
      class="bg-card shadow-card rounded-3xl px-6 pt-8 pb-7 text-center lg:sticky lg:top-8 lg:px-10 lg:pt-12 lg:pb-10"
    >
      <p class="text-muted-foreground text-xs font-semibold tracking-wide uppercase">
        {vehicle.production_year ? `${vehicle.production_year} · ` : ""}{categoryLabelPl(vehicle.category)}
      </p>
      <h1 class="text-foreground mt-2 text-4xl font-bold tracking-tight sm:text-5xl lg:text-6xl">{title}</h1>
      <div class="mt-3 inline-flex">
        <StatusPill />
      </div>

      <div class="text-foreground mt-4 lg:mt-8">
        {
          vehicle.photos.length > 0 ? (
            <VehicleGallery photos={vehicle.photos} alt={title} client:idle />
          ) : (
            <div class="flex items-center justify-center px-2">
              <VehicleSilhouette
                category={vehicle.category}
                photos={vehicle.photos}
                alt={title}
                class="max-w-[320px] lg:max-w-[440px]"
              />
            </div>
          )
        }
      </div>
    </header>

    <!-- Details: on tablet (md) specs + pricing sit side by side; on desktop (lg)
         they re-stack inside the narrower right column. -->
    <div class="md:grid md:grid-cols-2 md:items-start md:gap-x-8 md:pt-7 lg:grid-cols-1 lg:gap-y-6 lg:pt-0">
      <!-- Specifications -->
      <section class="pt-7 md:pt-0">
        <h2 class="text-muted-foreground px-1 pb-2.5 text-[13px] font-bold tracking-wide uppercase">Specyfikacja</h2>
        <dl class="bg-card shadow-card divide-y divide-[var(--flota-hair-2)] rounded-2xl">
          {
            specs.map((spec) => (
              <div class="flex items-center gap-3.5 px-4 py-3.5">
                <span class="bg-background text-foreground flex size-8 shrink-0 items-center justify-center rounded-[10px]">
                  <SpecIcon name={spec.icon} />
                </span>
                <dt class="text-muted-foreground flex-1 text-sm font-medium">{spec.label}</dt>
                <dd class="text-foreground text-sm font-semibold tracking-tight">{spec.value}</dd>
              </div>
            ))
          }
        </dl>
      </section>

      <!-- Pricing -->
      <section class="pt-6 md:pt-0">
        <h2 class="text-muted-foreground px-1 pb-2.5 text-[13px] font-bold tracking-wide uppercase">Cennik</h2>
        <div class="bg-card shadow-card grid grid-cols-2 gap-x-4 gap-y-4 rounded-2xl p-5">
          {
            pricing.map((item, i) => (
              <div class:list={[i < 4 && "border-b border-[var(--flota-hair-2)] pb-4"]}>
                <div class="text-muted-foreground text-[11px] font-semibold tracking-wide uppercase">{item.label}</div>
                <div
                  class:list={[
                    "text-foreground mt-1 tracking-tight",
                    item.big ? "text-lg font-bold" : "text-sm font-semibold",
                  ]}
                >
                  {item.value}
                </div>
              </div>
            ))
          }
        </div>
      </section>

      <!-- Inline CTA (desktop only — the fixed bottom bar covers mobile + tablet). -->
      <a
        href={reserveHref}
        class="bg-primary text-primary-foreground hidden h-13 w-full items-center justify-center gap-2 rounded-full px-6 text-[15px] font-semibold transition-colors hover:bg-[var(--flota-accent-dark)] lg:mt-2 lg:flex"
      >
        Zarezerwuj
        <span class="font-normal opacity-80">— {formatPln(vehicle.daily_rate)}/dzień</span>
        <svg
          class="size-4"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M5 12h14M13 6l6 6-6 6"></path>
        </svg>
      </a>
    </div>
  </div>
</article>

<!-- Fixed bottom CTA: mobile + tablet only; desktop uses the inline CTA above. -->
<div
  class="fixed inset-x-0 bottom-0 z-10 border-t border-[var(--flota-hair-2)] bg-[var(--flota-bg)]/95 backdrop-blur lg:hidden"
>
  <div class="mx-auto max-w-2xl px-5 py-4 sm:px-8 md:max-w-3xl">
    <a
      href={reserveHref}
      class="bg-primary text-primary-foreground flex h-13 w-full items-center justify-center gap-2 rounded-full px-6 text-[15px] font-semibold transition-colors hover:bg-[var(--flota-accent-dark)]"
    >
      Zarezerwuj
      <span class="font-normal opacity-80">— {formatPln(vehicle.daily_rate)}/dzień</span>
      <svg
        class="size-4"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.8"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M5 12h14M13 6l6 6-6 6"></path>
      </svg>
    </a>
  </div>
</div>
