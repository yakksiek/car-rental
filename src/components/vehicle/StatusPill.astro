---
// others
import { cn } from "../../lib/utils";

// Availability badge for catalog cards / detail (design screens 02/03/08). In
// S-01 every listed vehicle is bookable for the shown context (RLS hides
// inactive rows; the availability RPC excludes overlapping bookings), so the
// default is `available` → "Dostępny". `reserved` ("Zajęty") is wired for future
// surfaces that show non-bookable vehicles. Soft-tinted background + a dot, per
// the prototype's StatusBadge.

interface Props {
  status?: "available" | "reserved";
  class?: string;
}

const { status = "available", class: className } = Astro.props;

const VARIANTS = {
  available: { label: "Dostępny", classes: "bg-success/10 text-success" },
  reserved: { label: "Zajęty", classes: "bg-destructive/10 text-destructive" },
} as const;

const variant = VARIANTS[status];
---

<span
  class:list={cn(
    "inline-flex items-center gap-1.5 rounded-md px-2 py-1 text-[11px] font-semibold tracking-wide uppercase",
    variant.classes,
    className,
  )}
>
  <span class="size-1.5 rounded-full bg-current"></span>
  {variant.label}
</span>
