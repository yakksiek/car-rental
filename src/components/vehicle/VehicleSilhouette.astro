---
// others
import { cn } from "../../lib/utils";
import type { VehicleCategory } from "../../types";

// Geometric per-category silhouette (ported from the design prototype) shown when
// a vehicle has no photos — storage/photo upload is S-05, so `photos[]` is empty
// in the seed today. When a photo exists, render the first one instead. Stroke
// inherits `currentColor`; the parent sets the ink color.

interface Props {
  category: VehicleCategory;
  photos?: string[] | null;
  alt: string;
  class?: string;
}

const { category, photos, alt, class: className } = Astro.props;
const photo = photos?.[0] ?? null;

// vehicle_category → silhouette viewBox (each kind has its own aspect ratio).
const VIEWBOX: Record<VehicleCategory, string> = {
  cargo_van: "0 0 240 90",
  passenger_van: "0 0 240 90",
  car_transporter: "0 0 280 90",
  refrigerated_truck: "0 0 280 90",
  flatbed_truck: "0 0 280 90",
};
---

{
  photo ? (
    <img src={photo} alt={alt} class:list={cn("h-full w-full object-contain", className)} loading="lazy" />
  ) : (
    <svg
      class:list={cn("h-auto w-full max-w-full", className)}
      viewBox={VIEWBOX[category]}
      fill="none"
      stroke="currentColor"
      stroke-width="1.6"
      stroke-linecap="round"
      stroke-linejoin="round"
      role="img"
      aria-label={alt}
    >
      {category === "cargo_van" && (
        <>
          <path d="M10 74 L10 38 Q10 30 18 30 L80 30 L98 14 L200 14 Q210 14 210 24 L210 74" />
          <line x1="98" y1="14" x2="98" y2="30" />
          <rect x="105" y="22" width="80" height="20" rx="2" />
          <line x1="80" y1="30" x2="80" y2="42" />
          <line x1="10" y1="74" x2="210" y2="74" />
          <circle cx="40" cy="74" r="8" fill="currentColor" stroke="none" />
          <circle cx="40" cy="74" r="3.5" fill="#fff" stroke="none" />
          <circle cx="180" cy="74" r="8" fill="currentColor" stroke="none" />
          <circle cx="180" cy="74" r="3.5" fill="#fff" stroke="none" />
        </>
      )}

      {category === "passenger_van" && (
        <>
          <path d="M8 74 L8 38 Q8 28 18 28 L72 28 L88 12 L208 12 Q220 12 220 24 L220 74" />
          <rect x="92" y="20" width="22" height="18" rx="2" />
          <rect x="122" y="20" width="22" height="18" rx="2" />
          <rect x="152" y="20" width="22" height="18" rx="2" />
          <rect x="182" y="20" width="22" height="18" rx="2" />
          <rect x="34" y="38" width="36" height="18" rx="2" />
          <line x1="8" y1="74" x2="220" y2="74" />
          <circle cx="40" cy="74" r="8" fill="currentColor" stroke="none" />
          <circle cx="40" cy="74" r="3.5" fill="#fff" stroke="none" />
          <circle cx="180" cy="74" r="8" fill="currentColor" stroke="none" />
          <circle cx="180" cy="74" r="3.5" fill="#fff" stroke="none" />
        </>
      )}

      {category === "car_transporter" && (
        <>
          <path d="M8 74 L8 36 Q8 26 18 26 L58 26 L70 14 L88 14 Q94 14 94 22 L94 74" />
          <rect x="22" y="34" width="48" height="24" rx="2" />
          <path d="M94 56 L270 56 L270 64 L94 64 Z" />
          <path d="M260 56 L270 40 L270 56" />
          <path d="M130 56 L138 44 L210 44 L226 56" />
          <circle cx="150" cy="56" r="4" fill="currentColor" stroke="none" />
          <circle cx="210" cy="56" r="4" fill="currentColor" stroke="none" />
          <circle cx="42" cy="74" r="8" fill="currentColor" stroke="none" />
          <circle cx="42" cy="74" r="3.5" fill="#fff" stroke="none" />
          <circle cx="110" cy="74" r="8" fill="currentColor" stroke="none" />
          <circle cx="110" cy="74" r="3.5" fill="#fff" stroke="none" />
          <circle cx="230" cy="74" r="8" fill="currentColor" stroke="none" />
          <circle cx="230" cy="74" r="3.5" fill="#fff" stroke="none" />
          <circle cx="250" cy="74" r="8" fill="currentColor" stroke="none" />
          <circle cx="250" cy="74" r="3.5" fill="#fff" stroke="none" />
        </>
      )}

      {category === "refrigerated_truck" && (
        <>
          <path d="M8 74 L8 36 Q8 26 18 26 L58 26 L70 14 L88 14 Q94 14 94 22 L94 74" />
          <rect x="22" y="34" width="48" height="24" rx="2" />
          <rect x="98" y="10" width="170" height="64" rx="3" />
          <path d="M108 14 L108 28 M108 21 L130 21 M119 14 L119 28" opacity="0.7" />
          <rect x="245" y="18" width="18" height="14" rx="2" />
          <circle cx="42" cy="74" r="8" fill="currentColor" stroke="none" />
          <circle cx="42" cy="74" r="3.5" fill="#fff" stroke="none" />
          <circle cx="120" cy="74" r="8" fill="currentColor" stroke="none" />
          <circle cx="120" cy="74" r="3.5" fill="#fff" stroke="none" />
          <circle cx="240" cy="74" r="8" fill="currentColor" stroke="none" />
          <circle cx="240" cy="74" r="3.5" fill="#fff" stroke="none" />
        </>
      )}

      {category === "flatbed_truck" && (
        <>
          <path d="M8 74 L8 36 Q8 26 18 26 L58 26 L70 14 L88 14 Q94 14 94 22 L94 74" />
          <rect x="22" y="34" width="48" height="24" rx="2" />
          <path d="M98 30 Q100 22 108 22 L260 22 Q268 22 268 30 L268 60 L98 60 Z" />
          <path
            d="M108 22 L108 60 M138 22 L138 60 M168 22 L168 60 M198 22 L198 60 M228 22 L228 60 M258 22 L258 60"
            opacity="0.5"
          />
          <path d="M98 60 L268 60 L268 70 L98 70 Z" />
          <circle cx="42" cy="74" r="8" fill="currentColor" stroke="none" />
          <circle cx="42" cy="74" r="3.5" fill="#fff" stroke="none" />
          <circle cx="120" cy="74" r="8" fill="currentColor" stroke="none" />
          <circle cx="120" cy="74" r="3.5" fill="#fff" stroke="none" />
          <circle cx="240" cy="74" r="8" fill="currentColor" stroke="none" />
          <circle cx="240" cy="74" r="3.5" fill="#fff" stroke="none" />
        </>
      )}
    </svg>
  )
}
