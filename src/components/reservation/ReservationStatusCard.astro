---
// core
import { format } from "date-fns";
import { pl } from "date-fns/locale";

// components
import VehicleSilhouette from "../vehicle/VehicleSilhouette.astro";

// others
import { cn } from "../../lib/utils";
import { fromIsoDate } from "../../lib/date-iso";
import { estimatedTotal, formatDuration, formatPln, rentalDays } from "../../lib/format";
import type { ReservationStatus, ReservationStatusView } from "../../types";

// The status screen's header + booking summary (design desktop-3 / mobile-4):
// a soft-green check badge, the reference in crimson mono ABOVE the serif
// headline, a status pill, then a HORIZONTAL summary card — vehicle + dates on
// the left, the estimate (+ deposit) on the right — with the confirmation-email
// row folded in below a divider. Driven entirely by the get_reservation_status
// view row; no PII beyond the token holder's own request. The deposit (kaucja)
// is shown separately, never summed into the estimate.

interface Props {
  view: ReservationStatusView;
}

const { view } = Astro.props;

// Status pill, mirroring StatusPill's soft-tint + dot idiom. `pending` is the
// only status S-02 produces; confirmed/rejected/cancelled arrive with S-03.
const PILL: Record<ReservationStatus, { label: string; classes: string }> = {
  pending: { label: "Oczekuje", classes: "bg-warning/10 text-warning" },
  confirmed: { label: "Potwierdzone", classes: "bg-success/10 text-success" },
  rejected: { label: "Odrzucone", classes: "bg-destructive/10 text-destructive" },
  cancelled: { label: "Anulowane", classes: "bg-destructive/10 text-destructive" },
};
const pill = PILL[view.status];

const pickup = fromIsoDate(view.pickup_date);
const returnDate = fromIsoDate(view.return_date);
const days = rentalDays(view.pickup_date, view.return_date);
const metaLine =
  pickup && returnDate
    ? `${format(pickup, "d MMM", { locale: pl })} · 14:00 → ${format(returnDate, "d MMM", { locale: pl })} · 10:00 · ${formatDuration(days)}`
    : "—";

const title = [view.vehicle_make, view.vehicle_model].filter(Boolean).join(" ");
const total = formatPln(estimatedTotal(view.vehicle_daily_rate, days));
const deposit = formatPln(view.vehicle_deposit);
---

<section class="flex flex-col items-center text-center">
  <span class="bg-success/10 text-success flex size-14 items-center justify-center rounded-lg">
    <svg
      class="size-7"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M5 13l4 4 10-10"></path>
    </svg>
  </span>
  <p class="text-primary mt-5 font-mono text-sm font-medium tracking-wide">{view.reference}</p>
  <h1 class="text-foreground mt-1 font-serif text-4xl tracking-tight">Zgłoszenie przyjęte</h1>
  <p class="text-muted-foreground mt-2 text-sm">Bez konta — wszystko potwierdzimy e-mailem.</p>
  <span
    class:list={cn(
      "mt-4 inline-flex items-center gap-1.5 rounded-md px-2 py-1 text-[11px] font-semibold tracking-wide uppercase",
      pill.classes,
    )}
  >
    <span class="size-1.5 rounded-full bg-current"></span>
    {pill.label}
  </span>
</section>

<div class="bg-card shadow-card mt-7 rounded-lg p-5">
  <div class="flex items-center gap-4">
    <div class="text-foreground w-20 shrink-0">
      <VehicleSilhouette category={view.vehicle_category} alt={title} />
    </div>
    <div class="min-w-0 flex-1">
      <p class="text-foreground truncate text-base font-bold tracking-tight">{title}</p>
      <p class="text-muted-foreground mt-0.5 truncate text-sm">{metaLine}</p>
    </div>
    <div class="shrink-0 text-right">
      <p class="text-foreground text-lg font-bold tracking-tight">{total}</p>
      <p class="text-muted-foreground text-xs">+ kaucja {deposit}</p>
    </div>
  </div>

  <div class="text-muted-foreground mt-4 flex items-center gap-2.5 border-t border-[var(--flota-hair-2)] pt-4 text-sm">
    <svg
      class="size-4 shrink-0"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.7"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <rect x="3" y="5" width="18" height="14" rx="2"></rect>
      <path d="M3 7l9 6 9-6"></path>
    </svg>
    <span class="truncate">
      Potwierdzenie wysłaliśmy na <strong class="text-foreground font-semibold">{view.customer_email}</strong>
    </span>
  </div>
</div>
