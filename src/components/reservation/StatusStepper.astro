---
// others
import { cn } from "../../lib/utils";
import { stepperFor, type StepState } from "../../lib/reservation-status";
import type { ReservationStatus } from "../../types";

// The "CO DALEJ" section. Two layouts driven by the same Phase-2 step model
// (`stepperFor`):
//   • Mobile (< lg, design mobile-4): a vertical stepper — numbered circles
//     joined by a connecting line, title + description to the right.
//   • Desktop (lg+, design desktop-3): three horizontal cards, each a topic
//     icon + step number, title + description.
// The number badge carries the state in both — done = green check, current =
// navy filled, upcoming = grey outline. Astro-only; a status change arrives via
// a fresh page load.

interface Props {
  status: ReservationStatus;
  class?: string;
}

const { status, class: className } = Astro.props;

const steps = stepperFor(status);

// Number-badge styling per state (shared by both layouts).
const BADGE: Record<StepState, string> = {
  done: "bg-success text-white",
  current: "bg-foreground text-background",
  upcoming: "bg-background text-muted-foreground border border-[var(--flota-hair-2)]",
};
---

<section class:list={cn(className)}>
  <h2 class="text-muted-foreground text-[11px] font-semibold tracking-[0.14em] uppercase">Co dalej</h2>

  <!-- Mobile: vertical stepper (design mobile-4). -->
  <ol class="mt-4 lg:hidden">
    {
      steps.map((step, i) => (
        <li class="flex gap-3.5">
          <div class="flex flex-col items-center">
            <span
              class:list={cn(
                "flex size-7 shrink-0 items-center justify-center rounded-full text-xs font-semibold",
                BADGE[step.state],
              )}
            >
              {step.state === "done" ? (
                <svg
                  class="size-3.5"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M5 13l4 4 10-10" />
                </svg>
              ) : (
                i + 1
              )}
            </span>
            {i < steps.length - 1 && <span class="my-1.5 w-px flex-1 bg-[var(--flota-hair-2)]" />}
          </div>
          <div class:list={cn("min-w-0 pt-0.5", i < steps.length - 1 && "pb-6")}>
            <p
              class:list={cn(
                "text-sm leading-tight font-semibold",
                step.state === "upcoming" ? "text-muted-foreground" : "text-foreground",
              )}
            >
              {step.label}
            </p>
            <p class="text-muted-foreground mt-1 text-sm leading-snug">{step.description}</p>
          </div>
        </li>
      ))
    }
  </ol>

  <!-- Desktop: horizontal cards (design desktop-3). -->
  <ol class:list={cn("mt-4 hidden gap-3 lg:grid", steps.length >= 3 ? "lg:grid-cols-3" : "lg:grid-cols-2")}>
    {
      steps.map((step, i) => (
        <li
          class:list={cn(
            "bg-card shadow-card rounded-2xl p-5",
            step.state === "current" && "ring-foreground/10 ring-1",
          )}
        >
          <div class="flex items-start justify-between">
            <span class="bg-background text-foreground flex size-9 items-center justify-center rounded-full">
              <svg
                class="size-[18px]"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.7"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                {step.icon === "clock" && (
                  <>
                    <circle cx="12" cy="12" r="9" />
                    <path d="M12 7v5l3 2" />
                  </>
                )}
                {step.icon === "chat" && <path d="M4 5h16v11H8l-4 4z" />}
                {step.icon === "key" && (
                  <>
                    <circle cx="8" cy="8" r="4" />
                    <path d="M11 11l8 8M16 16l2-2M19 19l2-2" />
                  </>
                )}
                {step.icon === "x" && <path d="M6 6l12 12M18 6L6 18" />}
              </svg>
            </span>
            <span
              class:list={cn(
                "flex size-6 items-center justify-center rounded-full text-[11px] font-semibold",
                BADGE[step.state],
              )}
            >
              {step.state === "done" ? (
                <svg
                  class="size-3.5"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M5 13l4 4 10-10" />
                </svg>
              ) : (
                i + 1
              )}
            </span>
          </div>
          <p
            class:list={cn(
              "mt-3 text-sm font-semibold tracking-tight",
              step.state === "upcoming" ? "text-muted-foreground" : "text-foreground",
            )}
          >
            {step.label}
          </p>
          <p class="text-muted-foreground mt-1 text-sm leading-snug">{step.description}</p>
        </li>
      ))
    }
  </ol>
</section>
