---
// others
import { cn } from "../../lib/utils";
import { stepperFor, type StepState } from "../../lib/reservation-status";
import type { ReservationStatus } from "../../types";

// The "CO DALEJ" stepper (design screens 06 / mobile-4 / desktop-3). Pure
// presentation over the Phase-2 step model (`stepperFor`): each step is a bold
// title plus a one-line muted description; the current step is the crimson
// numbered node, done steps show a check, upcoming steps are hollow and greyed.
// Sits directly on the page background (no card), per the design. Astro-only —
// a status change arrives via a fresh page load.

interface Props {
  status: ReservationStatus;
  class?: string;
}

const { status, class: className } = Astro.props;

const steps = stepperFor(status);

const NODE_CLASSES: Record<StepState, string> = {
  done: "bg-foreground text-background",
  current: "bg-primary text-primary-foreground",
  upcoming: "border border-[var(--flota-hair-2)] bg-card text-muted-foreground",
};
---

<section class:list={cn(className)}>
  <h2 class="text-muted-foreground text-[11px] font-semibold tracking-[0.14em] uppercase">Co dalej</h2>
  <ol class="mt-4">
    {
      steps.map((step, i) => (
        <li class="flex gap-3.5">
          <div class="flex flex-col items-center">
            <span
              class:list={cn(
                "flex size-8 shrink-0 items-center justify-center rounded-full text-[13px] font-semibold",
                NODE_CLASSES[step.state],
              )}
            >
              {step.state === "done" ? (
                <svg
                  class="size-4"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M5 13l4 4 10-10" />
                </svg>
              ) : (
                i + 1
              )}
            </span>
            {i < steps.length - 1 && <span class="my-1.5 w-px flex-1 bg-[var(--flota-hair-2)]" />}
          </div>
          <div class:list={cn("min-w-0 pt-1.5", i < steps.length - 1 && "pb-7")}>
            <p
              class:list={cn(
                "text-sm leading-tight font-semibold",
                step.state === "upcoming" ? "text-muted-foreground" : "text-foreground",
              )}
            >
              {step.label}
            </p>
            <p class="text-muted-foreground mt-1 text-sm leading-snug">{step.description}</p>
          </div>
        </li>
      ))
    }
  </ol>
</section>
