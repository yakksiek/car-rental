---
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";

import "../styles/global.css";
import Banner from "../components/Banner.astro";
import { missingConfigs } from "../lib/config-status";

interface Props {
  title?: string;
}

const { title = "Flota — wynajem pojazdów użytkowych" } = Astro.props;
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <Font cssVariable="--font-inter" preload />
    <Font cssVariable="--font-instrument-serif" />
    <Font cssVariable="--font-jetbrains-mono" />
    <ClientRouter />
    <title>{title}</title>
    <slot name="head" />
  </head>
  <body>
    {
      missingConfigs.map((cfg) => (
        <Banner variant="error">
          <strong>Uwaga:</strong> {cfg.message}
          {cfg.docsUrl && (
            <>
              {" "}
              <a href={cfg.docsUrl} target="_blank" rel="noopener noreferrer">
                {cfg.docsLabel ?? "Dokumentacja"}
              </a>
              .
            </>
          )}
        </Banner>
      ))
    }
    <slot />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
