---
// components
import Layout from "../layouts/Layout.astro";

// others
import { listPendingReservations } from "../lib/services/reservations";

const { user, role, supabase } = Astro.locals;

// Cheap pending count for the queue entry card (mirrors the desktop "Need a
// decision" panel intent; the full mini-list lands with the desktop pass).
const pending = await listPendingReservations(supabase);
const pendingCount = pending.length;
---

<Layout title="Pulpit — Flota">
  <main class="mx-auto min-h-screen w-full max-w-2xl px-4 py-8">
    <header class="mb-6 flex items-start justify-between gap-4 px-1">
      <div>
        <h1 class="text-foreground text-2xl font-bold tracking-tight">Pulpit</h1>
        <p class="text-muted-foreground mt-1 text-sm">
          {user?.email}{role ? ` · ${role}` : ""}
        </p>
      </div>
      <form method="POST" action="/api/auth/signout">
        <button
          type="submit"
          class="border-border bg-card text-foreground shadow-card hover:bg-background rounded-[14px] border px-4 py-2 text-sm font-medium"
        >
          Wyloguj
        </button>
      </form>
    </header>

    <div class="flex flex-col gap-3">
      <a
        href="/dashboard/reservations"
        class="border-border bg-card shadow-card hover:bg-background flex items-center justify-between gap-4 rounded-2xl border p-5 transition-colors"
      >
        <div>
          <div class="text-foreground text-base font-[650] tracking-tight">Oczekujące wnioski</div>
          <div class="text-muted-foreground mt-0.5 text-sm">Zatwierdź lub odrzuć zgłoszenia rezerwacji</div>
        </div>
        <div class="flex items-center gap-3">
          {
            pendingCount > 0 && (
              <span class="text-warning flex min-w-7 items-center justify-center rounded-full bg-[var(--flota-warning-soft)] px-2 py-0.5 text-sm font-bold">
                {pendingCount}
              </span>
            )
          }
          <span class="text-muted-foreground" aria-hidden="true">→</span>
        </div>
      </a>

      <a
        href="/dashboard/calendar"
        class="border-border bg-card shadow-card hover:bg-background flex items-center justify-between gap-4 rounded-2xl border p-5 transition-colors"
      >
        <div>
          <div class="text-foreground text-base font-[650] tracking-tight">Kalendarz</div>
          <div class="text-muted-foreground mt-0.5 text-sm">Oś czasu rezerwacji według pojazdów</div>
        </div>
        <span class="text-muted-foreground" aria-hidden="true">→</span>
      </a>
    </div>
  </main>
</Layout>
