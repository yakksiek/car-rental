---
// components
import Layout from "../layouts/Layout.astro";
import StaffShell from "../components/shell/StaffShell.astro";
import NeedDecisionPanel from "../components/dashboard/NeedDecisionPanel";

// others
import { listPendingReservations } from "../lib/services/reservations";
import { staffIdentity } from "../lib/staff-identity";

const { user, role, supabase } = Astro.locals;

// The pending queue feeds both the shell badge and the dashboard "Wymaga decyzji"
// mini-list (L3) — the in-scope slice of the design's dispatch dashboard.
const pending = await listPendingReservations(supabase);
const pendingCount = pending.length;

const { initials } = staffIdentity(user?.email, role);

// Mobile hero date — "Czw · 18 czerwca". Formatted from PL arrays (workerd ICU is
// not guaranteed for toLocaleDateString).
const now = new Date();
const PL_DAYS = ["Niedz", "Pon", "Wt", "Śr", "Czw", "Pt", "Sob"];
const PL_MONTHS = [
  "stycznia",
  "lutego",
  "marca",
  "kwietnia",
  "maja",
  "czerwca",
  "lipca",
  "sierpnia",
  "września",
  "października",
  "listopada",
  "grudnia",
];
const dateLabel = `${PL_DAYS[now.getDay()]} · ${now.getDate()} ${PL_MONTHS[now.getMonth()]}`;
---

<Layout title="Pulpit — Flota">
  <StaffShell active="dash" title="Pulpit" user={user} role={role} pendingCount={pendingCount}>
    <main class="mx-auto w-full max-w-2xl px-4 py-8">
      {/* Mobile hero (the desktop topbar carries the title at md+) */}
      <header class="mb-6 flex items-start justify-between gap-4 px-1 md:hidden">
        <div>
          <div class="text-muted-foreground text-xs font-semibold tracking-wide uppercase">{dateLabel}</div>
          <h1 class="text-foreground mt-1 text-[32px] leading-none font-bold tracking-tight">Pulpit</h1>
          <p class="text-muted-foreground mt-1.5 text-sm">{user?.email}</p>
        </div>
        <span
          class="bg-primary text-primary-foreground shadow-accent flex size-11 shrink-0 items-center justify-center rounded-full text-base font-medium"
        >
          {initials}
        </span>
      </header>

      <div class="flex flex-col gap-6">
        {
          /* In-scope L3 slice: the pending queue surfaced as a quick-action
            mini-list with inline decide + an "Otwórz →" link to the full queue. */
        }
        <NeedDecisionPanel client:load reservations={pending} />

        <a
          href="/dashboard/calendar"
          class="border-border bg-card shadow-card hover:bg-background flex items-center justify-between gap-4 rounded-2xl border p-5 transition-colors"
        >
          <div>
            <div class="text-foreground text-base font-[650] tracking-tight">Kalendarz</div>
            <div class="text-muted-foreground mt-0.5 text-sm">Oś czasu rezerwacji według pojazdów</div>
          </div>
          <span class="text-muted-foreground" aria-hidden="true">→</span>
        </a>
      </div>
    </main>
  </StaffShell>
</Layout>
