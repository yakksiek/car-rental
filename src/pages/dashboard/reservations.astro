---
// components
import Layout from "../../layouts/Layout.astro";
import StaffShell from "../../components/shell/StaffShell.astro";
import PendingQueue from "../../components/dashboard/PendingQueue";

// others
import { countOverdueReturns } from "../../lib/services/protocols";
import { listPendingReservations } from "../../lib/services/reservations";

// Employee pending-request queue (S-03). The /dashboard/reservations route is
// gated to `employee` by the middleware (src/lib/access.ts); this page SSRs the
// pending list through the role-gated definer RPC and mounts the decision island.
const { user, role, supabase } = Astro.locals;
const reservations = await listPendingReservations(supabase);
const count = reservations.length;
const overdueCount = await countOverdueReturns(supabase);
const countLabel = `${count} oczekuje na decyzję`;
---

<Layout title="Oczekujące wnioski — Flota">
  <StaffShell
    active="requests"
    title="Oczekujące wnioski"
    subtitle={countLabel}
    user={user}
    role={role}
    pendingCount={count}
    overdueCount={overdueCount}
  >
    <main class="mx-auto w-full max-w-5xl px-4 py-6">
      {/* Mobile centered header (the desktop topbar carries this at md+) — L4 */}
      <header class="mb-4 text-center md:hidden">
        <h1 class="text-foreground text-xl font-bold tracking-tight">Oczekujące wnioski</h1>
        <p class="text-muted-foreground mt-1 text-sm">{countLabel}</p>
      </header>
      <PendingQueue client:load reservations={reservations} />
    </main>
  </StaffShell>
</Layout>
