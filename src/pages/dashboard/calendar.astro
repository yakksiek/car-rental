---
// components
import Layout from "../../layouts/Layout.astro";
import StaffShell from "../../components/shell/StaffShell.astro";
import ReservationCalendar from "../../components/dashboard/ReservationCalendar";

// others
import { listPendingReservations, listReservationsForCalendar } from "../../lib/services/reservations";
import { listVehicles } from "../../lib/services/vehicles";
import { countOverdueReturns } from "../../lib/services/protocols";
import { vehiclesToResources } from "../../lib/calendar/map";

// Reservation calendar (S-03 Phase 7). Employee-gated by the middleware. SSR the
// initial window's vehicles (resource rows) + reservations, then mount the
// client:only island (the lib never SSRs in workerd). The island refetches on
// navigation via GET /api/reservations/calendar.
const { user, role, supabase } = Astro.locals;
const pendingCount = (await listPendingReservations(supabase)).length;
const overdueCount = await countOverdueReturns(supabase);

// Optional focus deep-link (L5): /dashboard/calendar?view=week&date=YYYY-MM-DD&vehicle=<id>.
// Sent by a request's "Daty zarezerwowane" card so the calendar opens on that
// booking's window + vehicle instead of today. Validated; bad values fall back.
const dateParam = Astro.url.searchParams.get("date");
const viewParam = Astro.url.searchParams.get("view");
const focusDate = dateParam && /^\d{4}-\d{2}-\d{2}$/.test(dateParam) ? dateParam : undefined;
const initialView: "week" | "month" = viewParam === "week" ? "week" : "month";
const focusVehicleId = Astro.url.searchParams.get("vehicle") ?? undefined;

// Anchor the SSR data window on the focused date (else today), so the booking is
// already loaded when the island mounts on that window.
const anchor = focusDate ? new Date(`${focusDate}T00:00:00Z`) : new Date();
const windowStart = new Date(anchor);
windowStart.setDate(windowStart.getDate() - 31);
const windowEnd = new Date(anchor);
windowEnd.setDate(windowEnd.getDate() + 62);
const isoDate = (d: Date) => d.toISOString().slice(0, 10);

// Active vehicles only (listVehicles already restricts to is_active). See the
// plan's Migration Notes on the S-04 listVehicles coupling.
const vehicles = await listVehicles(supabase, {
  category: null,
  pickup: null,
  return: null,
  minPayload: null,
  sort: null,
});
const resources = vehiclesToResources(vehicles);
const reservations = await listReservationsForCalendar(supabase, isoDate(windowStart), isoDate(windowEnd));
---

<Layout title="Kalendarz — Flota">
  <StaffShell
    active="cal"
    title="Kalendarz"
    subtitle="Oś czasu rezerwacji według pojazdów"
    user={user}
    role={role}
    pendingCount={pendingCount}
    overdueCount={overdueCount}
  >
    <main class="mx-auto w-full max-w-6xl px-4 py-6">
      {/* Mobile centered header (the desktop topbar carries this at md+) */}
      <header class="mb-4 text-center md:hidden">
        <h1 class="text-foreground text-xl font-bold tracking-tight">Kalendarz</h1>
        <p class="text-muted-foreground mt-1 text-sm">Oś czasu rezerwacji według pojazdów</p>
      </header>
      <ReservationCalendar
        client:only="react"
        resources={resources}
        reservations={reservations}
        initialDate={focusDate}
        initialView={initialView}
        focusVehicleId={focusVehicleId}
      />
    </main>
  </StaffShell>
</Layout>
