---
import AuthShell from "../../components/auth/AuthShell.astro";
import ResetPasswordForm from "../../components/auth/ResetPasswordForm";

// Set-password surface (S-08). Requires the recovery/invite session established
// by /auth/callback's code exchange (locals.user). Renders:
//   • ?done=1  → R4 success ("Hasło zaktualizowane")
//   • no user  → R5 expired ("Link wygasł") — the session never landed
//   • else     → the set-password island in recovery (R3/R9) or invite (R6/R10) mode
const done = Astro.url.searchParams.get("done") === "1";
const mode = Astro.url.searchParams.get("mode") === "invite" ? "invite" : "recovery";
const error = Astro.url.searchParams.get("error");
const user = Astro.locals.user;
---

<AuthShell pageTitle="Strefa pracownika — ustaw hasło">
  {
    done ? (
      <div class="flex flex-col gap-[18px]">
        <div>
          <h1 class="text-foreground text-[28px] leading-[1.05] font-bold tracking-[-0.8px]">Hasło zaktualizowane</h1>
          <p class="text-muted-foreground mt-2 text-sm leading-[1.45]">Możesz teraz zalogować się nowym hasłem.</p>
        </div>
        <a
          href="/auth/signin"
          class="bg-primary text-primary-foreground inline-flex h-12 items-center justify-center gap-1.5 rounded-xl px-4 text-sm font-semibold"
        >
          Przejdź do logowania <span aria-hidden="true">→</span>
        </a>
      </div>
    ) : !user ? (
      <div class="flex flex-col gap-[18px]">
        <div>
          <h1 class="text-foreground text-[28px] leading-[1.05] font-bold tracking-[-0.8px]">Link wygasł</h1>
          <p class="text-muted-foreground mt-2 text-sm leading-[1.45]">
            Linki resetujące są ważne 60 minut. Poproś o nowy, aby kontynuować.
          </p>
        </div>
        <a
          href="/auth/forgot-password"
          class="bg-primary text-primary-foreground inline-flex h-12 items-center justify-center gap-1.5 rounded-xl px-4 text-sm font-semibold"
        >
          Poproś o nowy link <span aria-hidden="true">→</span>
        </a>
      </div>
    ) : (
      <ResetPasswordForm mode={mode} serverError={error} client:load />
    )
  }
</AuthShell>
