---
import AuthShell from "../../components/auth/AuthShell.astro";
import ForgotPasswordForm from "../../components/auth/ForgotPasswordForm";

// Forgot-password entry (S-08, designs R1/R7 request · R2/R8 check-email). The
// POST route always redirects here with ?sent=1 (neutral, no existence leak), so
// the same page renders the request form or the check-email confirmation. An
// expired/invalid recovery link routes back here with ?expired=1 (R5).
const sent = Astro.url.searchParams.get("sent") === "1";
const expired = Astro.url.searchParams.get("expired") === "1";
---

<AuthShell pageTitle="Strefa pracownika — reset hasła">
  {
    expired ? (
      <div class="flex flex-col gap-[18px]">
        <div>
          <h1 class="text-foreground text-[28px] leading-[1.05] font-bold tracking-[-0.8px]">Link wygasł</h1>
          <p class="text-muted-foreground mt-2 text-sm leading-[1.45]">
            Linki resetujące są ważne 60 minut. Poproś o nowy, aby kontynuować.
          </p>
        </div>
        <a
          href="/auth/forgot-password"
          class="bg-primary text-primary-foreground inline-flex h-12 items-center justify-center gap-1.5 rounded-xl px-4 text-sm font-semibold"
        >
          Poproś o nowy link <span aria-hidden="true">→</span>
        </a>
      </div>
    ) : sent ? (
      <div class="flex flex-col gap-[18px]">
        <div>
          <h1 class="text-foreground text-[28px] leading-[1.05] font-bold tracking-[-0.8px]">Sprawdź skrzynkę</h1>
          <p class="text-muted-foreground mt-2 text-sm leading-[1.45]">
            Jeśli dla tego adresu istnieje konto, link do resetu jest już w drodze. Wygasa po 60 minutach.
          </p>
        </div>
        <a
          href="/auth/signin"
          class="text-muted-foreground hover:text-foreground inline-flex items-center justify-center gap-1.5 text-sm transition-colors"
        >
          <span aria-hidden="true">‹</span> Powrót do logowania
        </a>
      </div>
    ) : (
      <ForgotPasswordForm client:load />
    )
  }
</AuthShell>
