---
import Layout from "../../layouts/Layout.astro";
import SignInForm from "../../components/auth/SignInForm";
import { safeRedirectPath } from "../../lib/safe-redirect";

// Staff sign-in ("Strefa pracownika"). Mobile: dark ink brand band over a white
// form. Desktop: a centered 440px modal card over a blurred dispatch-workspace
// backdrop + dark scrim. Source: design `staff-login.jsx` (Screen…Mobile /
// Screen…Desktop + LoginForm), copy from `shared.jsx` STR.PL.login.
const error = Astro.url.searchParams.get("error");
const redirectTo = safeRedirectPath(Astro.url.searchParams.get("redirect"));
---

<Layout title="Strefa pracownika — logowanie">
  <div class="relative flex min-h-screen flex-col md:items-center md:justify-center md:p-10">
    {/* ── Desktop: blurred dispatch backdrop + scrim (decorative) ──────── */}
    <div aria-hidden="true" class="absolute inset-0 hidden overflow-hidden md:block">
      <div class="bg-background flex h-full scale-[1.04] blur-[7px]">
        <div class="bg-card border-border flex w-[240px] flex-col gap-2 border-r px-3.5 py-6">
          <div class="flex items-center gap-2.5 px-1.5 pb-4">
            <div class="bg-primary size-[30px] rounded-[9px]"></div>
            <div class="h-3 w-[90px] rounded bg-[var(--flota-hair)]"></div>
          </div>
          {
            [0, 1, 2, 3].map((i) => (
              <div class:list={["h-[38px] rounded-[10px]", i === 0 ? "bg-foreground/90" : "bg-secondary"]} />
            ))
          }
        </div>
        <div class="flex-1 p-7">
          <div class="border-border mb-5 flex h-11 items-center justify-between border-b">
            <div class="h-5 w-[200px] rounded bg-[var(--flota-hair)]"></div>
            <div class="bg-secondary h-[34px] w-[130px] rounded-[9px]"></div>
          </div>
          <div class="mb-4 grid grid-cols-3 gap-3.5">
            {[0, 1, 2].map(() => <div class="bg-card shadow-card h-[86px] rounded-[14px]" />)}
          </div>
          <div class="flex flex-col gap-3">
            {[0, 1, 2, 3].map(() => <div class="bg-card shadow-card h-16 rounded-[14px]" />)}
          </div>
        </div>
      </div>
    </div>
    <div aria-hidden="true" class="absolute inset-0 hidden bg-[rgba(15,23,42,0.55)] md:block"></div>

    {/* ── Mobile: dark ink brand band ─────────────────────────────────── */}
    <div class="relative overflow-hidden bg-[var(--flota-ink)] px-6 pt-14 pb-7 text-white md:hidden">
      <div class="pointer-events-none absolute -right-8 -bottom-4 opacity-[0.14]">
        <svg
          viewBox="0 0 240 90"
          width="260"
          fill="none"
          stroke="#fff"
          stroke-width="1.6"
          stroke-linejoin="round"
          stroke-linecap="round"
        >
          <path d="M10 74 L10 38 Q10 30 18 30 L80 30 L98 14 L200 14 Q210 14 210 24 L210 74"></path>
          <line x1="98" y1="14" x2="98" y2="30"></line>
          <rect x="105" y="22" width="80" height="20" rx="2"></rect>
          <line x1="80" y1="30" x2="80" y2="42"></line>
          <line x1="10" y1="74" x2="210" y2="74"></line>
          <circle cx="40" cy="74" r="8" fill="#fff" stroke="none" opacity="0.92"></circle>
          <circle cx="180" cy="74" r="8" fill="#fff" stroke="none" opacity="0.92"></circle>
        </svg>
      </div>
      <a
        href="/"
        class="mb-7 inline-flex items-center gap-1.5 text-[12.5px] font-semibold text-white/70 transition-colors hover:text-white"
      >
        <svg
          width="15"
          height="15"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.7"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="m15 6-6 6 6 6"></path>
        </svg>
        Powrót do flota.pl
      </a>
      <div class="relative flex items-center gap-3">
        <span
          class="bg-primary text-primary-foreground flex size-[42px] shrink-0 items-center justify-center rounded-[13px] font-serif text-[27px] leading-none shadow-[0_6px_16px_rgba(180,54,56,0.30)]"
          >F</span
        >
        <div class="leading-none">
          <div class="text-[18px] font-bold tracking-[-0.3px]">Flota</div>
          <div class="mt-[3px] font-mono text-[10.5px] font-semibold tracking-[0.5px] text-white/65 uppercase">
            Strefa pracownika
          </div>
        </div>
      </div>
    </div>

    {/* ── Card / form panel (mobile: white sheet · desktop: modal) ────── */}
    <div
      class="bg-card md:shadow-overlay relative z-10 flex flex-1 flex-col px-6 py-7 md:w-[440px] md:flex-none md:rounded-[20px] md:px-10 md:py-9"
    >
      <div class="mb-6 hidden items-center gap-3 md:flex">
        <span
          class="bg-primary text-primary-foreground flex size-10 shrink-0 items-center justify-center rounded-xl font-serif text-[26px] leading-none shadow-[0_6px_16px_rgba(180,54,56,0.30)]"
          >F</span
        >
        <div class="leading-none">
          <div class="text-foreground text-[17px] font-bold tracking-[-0.3px]">Flota</div>
          <div class="text-muted-foreground mt-[3px] font-mono text-[10.5px] font-semibold tracking-[0.5px] uppercase">
            Strefa pracownika
          </div>
        </div>
      </div>

      <SignInForm serverError={error} redirectTo={redirectTo} client:load />

      <div
        class="text-muted-foreground border-border/60 mt-auto flex items-center justify-center gap-1.5 border-t pt-[18px] text-[12.5px] md:mt-6"
      >
        <span>Problem z logowaniem?</span>
        <span class="text-foreground font-[650]">Skontaktuj się z administratorem</span>
      </div>
    </div>
  </div>
</Layout>
