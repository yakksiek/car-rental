---
// components
import Layout from "../../layouts/Layout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import ReservationStatusCard from "../../components/reservation/ReservationStatusCard.astro";
import StatusStepper from "../../components/reservation/StatusStepper.astro";

// others
import { getReservationStatus } from "../../lib/services/reservations";

// Tokenized reservation status route (design screens 06 / mobile-4 / desktop-3).
// One screen, two arrivals: the post-submit "Zgłoszenie przyjęte" landing and the
// durable status link the confirmation email carries. The `access_token` path
// segment is the only credential — resolution crosses the RLS boundary through
// the `get_reservation_status` definer RPC (`reservations` stays anon-denied),
// and an unknown/malformed token yields `null` → a styled HTTP 404. The URL is
// a bearer secret, so the page is marked noindex.

const { token } = Astro.params;
const supabase = Astro.locals.supabase;

const view = token ? await getReservationStatus(supabase, token) : null;

if (!view) {
  Astro.response.status = 404;
}

const title = view ? `Zgłoszenie ${view.reference}` : "Nie znaleziono zgłoszenia";
---

<Layout title={`${title} — Flota`}>
  <meta slot="head" name="robots" content="noindex" />
  <SiteHeader />
  {
    view ? (
      <main class="mx-auto max-w-3xl px-5 py-10 sm:px-8 sm:py-14">
        <ReservationStatusCard view={view} />
        <StatusStepper status={view.status} class="mt-8" />
        {/* Two actions (design desktop-3): ghost "back" + navy "browse". */}
        <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:justify-center">
          <a
            href="/fleet"
            class="border-input text-foreground hover:bg-accent rounded-button inline-flex h-11 items-center justify-center border bg-transparent px-6 text-sm font-semibold transition-colors"
          >
            Wróć do floty
          </a>
          <a
            href="/fleet"
            class="bg-foreground text-background rounded-button inline-flex h-11 items-center justify-center gap-1.5 px-6 text-sm font-semibold"
          >
            Przeglądaj flotę
            <svg
              class="size-3.5"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.7"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M5 12h14M13 6l6 6-6 6" />
            </svg>
          </a>
        </div>
      </main>
    ) : (
      <main class="mx-auto max-w-2xl px-5 py-24 text-center sm:px-8">
        <p class="text-muted-foreground text-xs font-semibold tracking-wide uppercase">Błąd 404</p>
        <h1 class="text-foreground mt-3 text-3xl font-bold tracking-tight">Nie znaleziono zgłoszenia</h1>
        <p class="text-muted-foreground mx-auto mt-3 max-w-md">
          To zgłoszenie nie istnieje lub link jest nieprawidłowy. Sprawdź adres z e-maila potwierdzającego.
        </p>
        <a
          href="/fleet"
          class="bg-foreground text-background rounded-button mt-7 inline-flex h-11 items-center px-6 text-sm font-semibold"
        >
          Wróć do floty
        </a>
      </main>
    )
  }
  <SiteFooter />
</Layout>
