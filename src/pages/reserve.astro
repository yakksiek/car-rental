---
// components
import Layout from "../layouts/Layout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import VehicleSilhouette from "../components/vehicle/VehicleSilhouette.astro";
import ReservationForm from "../components/reservation/ReservationForm.tsx";

// others
import { validateDateRange } from "../lib/catalog-filters";
import { getVehicleById } from "../lib/services/vehicles";

// Reservation flow step 2 — "Twoje dane" (design desktop-2 / mobile-3). The
// date range is chosen at step 1 on the vehicle detail page (the BookingWidget),
// so this page REQUIRES a valid carried range: SSR resolves the vehicle
// (missing/inactive/malformed id → styled 404) and, when the range is absent or
// invalid, shows a "pick your dates" prompt linking back to step 1. Otherwise it
// hosts the ReservationForm island (customer fields + order summary), which
// submits to POST /api/reservations and redirects to /r/<token> (step 3). The
// funnel is transactional and per-vehicle — noindex, like the status page.

const supabase = Astro.locals.supabase;
const vehicleId = Astro.url.searchParams.get("vehicle_id");

const vehicle = vehicleId ? await getVehicleById(supabase, vehicleId) : null;

const rawPickup = Astro.url.searchParams.get("pickup");
const rawReturn = Astro.url.searchParams.get("return");
const datesOk = Boolean(rawPickup && rawReturn && validateDateRange(rawPickup, rawReturn).ok);

// Dates live on step 1 now. A real vehicle reached without a valid range
// (manual URL, stale link) gets a prompt back to step 1 rather than a broken
// form; a missing/inactive vehicle is a 404.
const needsDates = Boolean(vehicle) && !datesOk;
if (!vehicle) {
  Astro.response.status = 404;
}

const title = vehicle ? [vehicle.make ?? vehicle.name, vehicle.model].filter(Boolean).join(" ") : null;

// Back to step 1 (the detail page) with the chosen range so the picker stays
// pre-filled (or just the vehicle when there's no valid range to carry).
const backHref = vehicle
  ? datesOk
    ? `/fleet/${vehicle.id}?pickup=${rawPickup}&return=${rawReturn}`
    : `/fleet/${vehicle.id}`
  : "/fleet";
---

<Layout title="Twoje dane — Flota">
  <meta slot="head" name="robots" content="noindex" />
  <SiteHeader />
  {
    vehicle && datesOk ? (
      <main class="lg:max-w-app mx-auto max-w-2xl px-5 pb-40 sm:px-8 lg:pb-16">
        <ReservationForm
          client:load
          vehicle={{
            id: vehicle.id,
            label: title ?? "",
            year: vehicle.production_year,
            dailyRate: vehicle.daily_rate,
            deposit: vehicle.deposit,
          }}
          pickup={rawPickup ?? ""}
          return={rawReturn ?? ""}
          backHref={backHref}
        >
          {/* Server-rendered silhouette for the order-summary thumbnail. */}
          <VehicleSilhouette category={vehicle.category} alt={title ?? ""} />
        </ReservationForm>
      </main>
    ) : needsDates ? (
      <main class="mx-auto max-w-2xl px-5 py-24 text-center sm:px-8">
        <p class="text-muted-foreground text-xs font-semibold tracking-wide uppercase">Krok 1 · Daty</p>
        <h1 class="text-foreground mt-3 text-3xl font-bold tracking-tight">Najpierw wybierz daty</h1>
        <p class="text-muted-foreground mx-auto mt-3 max-w-md">
          Aby zarezerwować ten pojazd, wybierz termin odbioru i zwrotu na stronie pojazdu.
        </p>
        <a
          href={backHref}
          class="bg-primary text-primary-foreground rounded-button mt-7 inline-flex h-11 items-center px-6 text-sm font-semibold transition-colors hover:bg-[var(--flota-accent-dark)]"
        >
          Wybierz daty
        </a>
      </main>
    ) : (
      <main class="mx-auto max-w-2xl px-5 py-24 text-center sm:px-8">
        <p class="text-muted-foreground text-xs font-semibold tracking-wide uppercase">Błąd 404</p>
        <h1 class="text-foreground mt-3 text-3xl font-bold tracking-tight">Nie znaleziono pojazdu</h1>
        <p class="text-muted-foreground mx-auto mt-3 max-w-md">
          Ten pojazd nie istnieje lub nie jest już dostępny w naszej flocie.
        </p>
        <a
          href="/fleet"
          class="bg-foreground text-background rounded-button mt-7 inline-flex h-11 items-center px-6 text-sm font-semibold"
        >
          Wróć do floty
        </a>
      </main>
    )
  }
  <SiteFooter />
</Layout>
