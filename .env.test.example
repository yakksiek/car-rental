# Integration-test credentials for the local Supabase stack.
#
# Copy this file to `.env.test` (gitignored) and fill in the values printed by:
#
#   npx supabase status
#
# Map the printed keys as follows:
#   SUPABASE_URL              -> "API URL"          (http://127.0.0.1:54321)
#   SUPABASE_ANON_KEY         -> "Publishable" key  (sb_publishable_...)
#   SUPABASE_SERVICE_ROLE_KEY -> "Secret" key       (sb_secret_...)
#
# Do NOT commit real values here. The service-role/Secret key bypasses RLS; the
# harness uses it ONLY for setup/teardown, never for access assertions. Real
# values belong only in the gitignored .env.test.

SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx
